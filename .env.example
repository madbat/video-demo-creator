# Copy this file to ".env" and fill in your real values.
# The .env file is gitignored and must never be committed.
#
#   PowerShell:  Copy-Item .env.example .env   (then edit .env)
#
# generate_dialogue.py and verify_dialogue.py auto-load this file (searching the
# current directory and its parents). Point at a specific file with the
# ELEVENLABS_ENV_FILE environment variable. Existing env vars always win.

# --- Required ---------------------------------------------------------------
ELEVENLABS_API_KEY=your-elevenlabs-api-key-here

# --- Optional: default voice ------------------------------------------------
# Used when a shot's JSON omits "voice_id", so you don't repeat it everywhere.
# An explicit per-line voice_id still takes precedence.
# ELEVENLABS_VOICE_ID=your-voice-id

# --- Optional: narration verification (verify_dialogue.py + whisper.cpp) -----
# Only needed if you run the optional back-transcription check.
# WHISPER_CLI=C:\tools\whisper.cpp\build\bin\whisper-cli.exe
# WHISPER_MODEL=C:\tools\whisper.cpp\models\ggml-base.bin
# WHISPER_LANG=sv

# Note: CLAUDE_SCREENSHOT_DIR (screenshot output folder) is read by the
# capture scripts from the shell environment, NOT from this .env file. Set it
# in PowerShell with:  $env:CLAUDE_SCREENSHOT_DIR = "D:\path\to\shots"
